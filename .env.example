# Environment Variables for FindMyTaste Project

# Database Configuration
POSTGRES_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Redis Configuration
REDIS_PASSWORD=your-redis-password

# Cloudinary Configuration
CLOUDINARY_STORAGE_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_STORAGE_API_KEY=your-cloudinary-api-key
CLOUDINARY_STORAGE_API_SECRET=your-cloudinary-api-secret

# Payment Gateway Configuration
FLUTTERWAVE_AUTH_TOKEN=your-flutterwave-token
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# Firebase Configuration
FIREBASE_CREDENTIALS_PATH=findmytaste-firebase-adminsdk.json

# Backblaze B2 Configuration
# Get these from your Backblaze B2 account dashboard
BACKBLAZE_APPLICATION_KEY_ID=your_backblaze_key_id_here
BACKBLAZE_APPLICATION_KEY=your_backblaze_application_key_here
BACKBLAZE_BUCKET_ID=your_backblaze_bucket_id_here
BACKBLAZE_BUCKET_NAME=your_backblaze_bucket_name_here

# Instructions for Backblaze B2 Setup:
# 1. Go to https://secure.backblaze.com/b2_buckets.htm
# 2. Create a new bucket or use an existing one
# 3. Go to App Keys section and create a new application key
# 4. Copy the Key ID and Application Key
# 5. Get your Bucket ID from the bucket details
# 6. Set the bucket name (the name you gave your bucket)